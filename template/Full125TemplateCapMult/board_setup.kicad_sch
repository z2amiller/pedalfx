	(text "Audio out to the jacks. Connected to EFFECT_OUT when\nthe footswitch is engaged, or JACK_IN when in bypass."
		(exclude_from_sim no)
		(at 231.14 116.332 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "9f0a25ca-ea61-40dc-8d03-f7f7b533f76e")
	)
	(text "Connected to GND when effect is engaged.\nUsually used to drive the \"effect on\" status LED."
		(exclude_from_sim no)
		(at 223.774 94.234 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c500f344-9b12-4523-953f-77e0adbfc14b")
	)
	(text "Can be used to power and test a PCB\nwithout soldering on the jacks/footswitch."
		(exclude_from_sim no)
		(at 140.462 74.676 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "cbae4b3b-60a9-4337-8bbb-091c590b592a")
	)
	(text "Cap multiplier (Q102):\n  +9VA = Vrail − Vbe − (Iload/hFE)·R102        ← R102 sees only Iload/hFE\n  Ripple rejection ≈ 1 / (2π·f·R102·Cbase)      Cbase = C103 (+C104)\n  → raise R102 and/or Cbase for more filtering;\n    lower R102 only if (Iload/hFE)·R102 eats headroom (>~50 mA loads)"
		(exclude_from_sim no)
		(at 59.69 129.794 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "cbb0e9a4-c12b-40a5-9ee5-4c7c1105068d")
	)
	(text "Optional - test loop pins.\nCan populate with ronghe/keystone\n5000 like C5199803 , leave as a PTH,\nor delete.\n"
		(exclude_from_sim no)
		(at 143.51 125.222 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "d53c032d-c875-4b58-8385-dfb109afc063")
	)
	(text "Input to the PCB.  Connected to JACK_IN\nwhen footswitch is engaged."
		(exclude_from_sim no)
		(at 221.488 82.296 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
